# Local machine overrides for PortPilot release signing.
# I keep this file as a template only. Copy it to `.port.local.env` and fill in the real values locally.

export APP_IDENTITY="Developer ID Application: Your Name (TEAMID)"
export APP_STORE_CONNECT_KEY_ID="ABCDEFGHIJ"
export APP_STORE_CONNECT_ISSUER_ID="00000000-0000-0000-0000-000000000000"
export APP_STORE_CONNECT_API_KEY_P8="$(cat /absolute/path/to/AuthKey_XXXXXXXXXX.p8)"
export SPARKLE_KEY_ACCOUNT="portpilot"
export SPARKLE_PRIVATE_KEY_FILE="$HOME/.config/portpilot/sparkle_private_key"
